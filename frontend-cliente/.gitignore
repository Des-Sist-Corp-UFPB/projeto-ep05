# =============================================================================
# .gitignore — Frontend Cliente (React / Vite)
# =============================================================================

# ---------------------------------------------------------------------------
# Dependências
# ---------------------------------------------------------------------------
node_modules/

# ---------------------------------------------------------------------------
# Build e outputs
# ---------------------------------------------------------------------------
dist/
dist-ssr/

# ---------------------------------------------------------------------------
# Testes e cobertura
# ---------------------------------------------------------------------------
coverage/

# ---------------------------------------------------------------------------
# Variáveis de ambiente — NUNCA versionar!
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
.env.local
.env.*.local

# ---------------------------------------------------------------------------
# Vite
# ---------------------------------------------------------------------------
*.local
vite.config.js.timestamp-*

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
