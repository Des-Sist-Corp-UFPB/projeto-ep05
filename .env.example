# =============================================================================
# Variáveis de ambiente — EXEMPLO
# =============================================================================
# INSTRUÇÕES:
#   1. Copie este arquivo: cp .env.example .env
#   2. Preencha os valores reais no .env
#   3. NUNCA faça commit do .env (ele está no .gitignore)
#
# No servidor de produção, este arquivo fica em:
#   /home/ghactions/mercado/.env
# A variável APP_IMAGE é atualizada automaticamente pelo GitHub Actions.
# =============================================================================

# Imagem Docker da aplicação (atualizada automaticamente pelo CI/CD a cada deploy)
# Substitua "usuario" pelo seu usuário ou organização no GitHub.
APP_IMAGE=ghcr.io/usuario/mercado:latest

# Banco de dados
DATABASE_URL=jdbc:postgresql://postgres:5432/mercado_prod
DATABASE_USERNAME=mercado
DATABASE_PASSWORD=troque-por-uma-senha-forte

# (Opcional) Porta da aplicação — padrão: 8080
# SERVER_PORT=8080


# =============================================================================
# .env.example — Template de variáveis de ambiente
# =============================================================================
# Copie este arquivo para .env.dev (desenvolvimento) ou .env.prod (produção)
# e preencha os valores. NUNCA suba .env.dev ou .env.prod para o Git.
#
# Para gerar um JWT secret seguro:
#   openssl rand -base64 64
# =============================================================================

# --- Banco de Dados ---
DATABASE_URL=jdbc:postgresql://postgres:5432/mercado_dev
DATABASE_USERNAME=
DATABASE_PASSWORD=

# --- Imagem Docker (apenas produção) ---
APP_IMAGE=ghcr.io/usuario/mercado:latest

# --- JWT ---
# ⚠️ Obrigatório — a aplicação NÃO sobe sem esta variável.
# Gere com: openssl rand -base64 64
APP_JWT_SECRET=

# --- Seed (usuários padrão criados na primeira execução) ---
APP_SEED_ADMIN_PASSWORD=

