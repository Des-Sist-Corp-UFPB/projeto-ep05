# =============================================================================
# .env.example — RAIZ DO MONOREPO (produção)
# =============================================================================
# Este é o .env usado por: docker compose -f docker/compose/single.yml
# (imagem única: frontend React + backend Spring Boot + nginx no mesmo
# container, gerada por docker/single/Dockerfile)
#
#   1. Copie: cp .env.example .env
#   2. Preencha os valores reais no .env (no servidor, não no seu computador)
#   3. NUNCA faça commit do .env — ele já está no .gitignore
#
# Local no servidor (dsc.rodrigor.com): a raiz do monorepo, ao lado da pasta docker/
# =============================================================================

# --- Imagem Docker única (atualizada automaticamente pelo CI/CD a cada deploy) ---
# Troque "usuario/repo" pelo nome real do repositório no GitHub (minúsculo).
APP_IMAGE=ghcr.io/usuario/repo:latest

# --- Banco de dados ---
DATABASE_URL=jdbc:postgresql://postgres:5432/mercado_prod
DATABASE_USERNAME=mercado
DATABASE_PASSWORD=troque-por-uma-senha-forte

# --- JWT ---
# Obrigatório — a aplicação não sobe sem esta variável.
# Gere com: openssl rand -base64 64
APP_JWT_SECRET=

# --- Seed (usuário admin criado na primeira execução) ---
APP_SEED_ADMIN_PASSWORD=

# --- Mercado Pago ---
# Chave de PRODUÇÃO (começa com APP_USR-). Nunca a chave de teste aqui.
MERCADOPAGO_ACCESS_TOKEN=

# --- Mercado Pago (frontend) ---
# Chave PÚBLICA (começa com APP_USR-) — usada só no build da imagem via
# --build-arg VITE_MP_PUBLIC_KEY, não em runtime. No deploy automático ela
# vem do secret VITE_MP_PUBLIC_KEY do GitHub Actions.
VITE_MP_PUBLIC_KEY=

# =============================================================================
# NOTA: a porta publicada pelo container (127.0.0.1:8105 neste projeto) é
# definida diretamente em docker/compose/single.yml, não aqui — porque é a
# porta fixa atribuída pelo proxy central do servidor da disciplina, não algo
# que varia por ambiente.
# =============================================================================
