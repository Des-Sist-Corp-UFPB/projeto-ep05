# =============================================================================
# .gitignore — Raiz do monorepo (projeto-ep05)
# Cada submódulo tem seu próprio .gitignore para regras específicas.
# Aqui ficam apenas as regras comuns a todo o repositório.
# =============================================================================

# ---------------------------------------------------------------------------
# IDEs
# ---------------------------------------------------------------------------
.idea/
*.iml
*.iws
*.ipr
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.swp
*~

# ---------------------------------------------------------------------------
# Sistema operacional
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
logs/

# ---------------------------------------------------------------------------
# Variáveis de ambiente — NUNCA versionar!
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
